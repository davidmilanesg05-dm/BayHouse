---
---
<div id="filter-modal" class="hidden absolute top-0 left-0 inset-0 bg-black/50 backdrop-blur-sm z-50 items-center justify-center w-full h-full">
  <div class="bg-card shadow-xl w-full h-full overflow-y-auto">
    <div class="p-6 border-b border-border flex justify-between items-center sticky top-0 bg-card z-10">
      <h3 class="text-xl font-bold text-foreground">Filtros Avanzados</h3>
      <button id="close-filter-modal" class="text-muted-foreground hover:text-foreground cursor-pointer" aria-label="Cerrar modal de filtros">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgX" aria-hidden="true"><path d="M5.636 5.636l12.728 12.728m-12.728 0L18.364 5.636m0 0"></path></svg>
      </button>
    </div>
    
    <div class="p-6 space-y-6">
      <!-- Filtro de Precio -->
      <div>
        <label class="block text-sm font-medium text-foreground mb-2">Rango de Precio</label>
        <div class="grid grid-cols-2 gap-4">
          <input type="number" id="min-price" placeholder="Mínimo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
          <input type="number" id="max-price" placeholder="Máximo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
        </div>
      </div>
      

      <!-- Filtro de Habitaciones -->
      <div>
        <label class="block text-sm font-medium text-foreground mb-2">Habitaciones</label>
        <div class="grid grid-cols-2 gap-4">
          <input type="number" id="min-beds" placeholder="Mínimo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
          <input type="number" id="max-beds" placeholder="Máximo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
        </div>
      </div>

      <!-- Filtro de Baños -->
      <div>
        <label class="block text-sm font-medium text-foreground mb-2">Baños</label>
        <div class="grid grid-cols-2 gap-4">
          <input type="number" id="min-baths" placeholder="Mínimo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
          <input type="number" id="max-baths" placeholder="Máximo" class="w-full px-4 py-3 border border-border bg-card text-foreground rounded-lg focus:ring-2 focus:ring-ring outline-none">
        </div>
      </div>
      <!-- Botones -->
      <div class="flex gap-4 pt-4">
        <button id="clear-filters-btn" class="flex-1 px-6 py-3 bg-muted hover:bg-muted/80 text-foreground font-semibold rounded-lg transition-colors">
          Limpiar
        </button>
        <button id="apply-filters-btn" class="flex-1 px-6 py-3 bg-primary hover:bg-primary/90 text-primary-foreground font-semibold rounded-lg transition-colors">
          Aplicar
        </button>
      </div>
    </div>
  </div>
</div>