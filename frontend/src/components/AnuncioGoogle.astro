---
const adClient = "ca-pub-1234567890123456"; // Tu ID de publicador
const adSlot = "9876543210"; // El ID de tu nuevo bloque de anuncios
---

<section class="py-12 bg-background">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h3 class="text-sm font-semibold text-muted-foreground mb-4 uppercase tracking-wider">Publicidad</h3>
    <div class="bg-gray-200 rounded-lg p-4 min-h-[280px] flex items-center justify-center">
      <!-- Google AdSense Code -->
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adClient}`}
           crossorigin="anonymous"></script>
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client={adClient}
           data-ad-slot={adSlot}
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
      <script>
           (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
      <span class="text-gray-500">Espacio para anuncio</span>
    </div>
  </div>
</section>