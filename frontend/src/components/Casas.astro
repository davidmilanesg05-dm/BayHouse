---
---

<section class="py-16 px-4 bg-seashell-50">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-10 text-seashell-900">Casas en Venta</h2>
    
    <div class="flex items-center gap-4 mb-10 max-w-3xl mx-auto">
      <div class="flex-1 relative">
        <input 
          type="text" 
          placeholder="Busca por ubicación, tipo de propiedad..." 
          class="w-full pl-12 pr-4 py-3 border border-seashell-200 rounded-full bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-seashell-400"
        />
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 transform -translate-y-1/2 text-seashell-400">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </div>
      
      <button class="p-3 bg-white border border-seashell-200 rounded-full shadow-sm hover:bg-seashell-100 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-700">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        {
          title: "Casa Moderna con Piscina",
          location: "Miami, Florida",
          price: "$850,000",
          beds: 4,
          baths: 3,
          sqft: 2800,
          image: "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=600&fit=crop"
        },
        {
          title: "Villa de Lujo con Vista al Mar",
          location: "Malibú, California",
          price: "$2,200,000",
          beds: 5,
          baths: 4,
          sqft: 4200,
          image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop"
        },
        {
          title: "Casa de Campo Amplia",
          location: "Austin, Texas",
          price: "$620,000",
          beds: 3,
          baths: 2,
          sqft: 2100,
          image: "https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop"
        },
        {
          title: "Apartamento de Lujo en el Centro",
          location: "Nueva York, NY",
          price: "$1,500,000",
          beds: 3,
          baths: 2,
          sqft: 1800,
          image: "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=800&h=600&fit=crop"
        },
        {
          title: "Casa Familiar con Jardín",
          location: "Chicago, Illinois",
          price: "$480,000",
          beds: 4,
          baths: 2,
          sqft: 2400,
          image: "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800&h=600&fit=crop"
        },
        {
          title: "Residencia Contemporánea",
          location: "Los Ángeles, California",
          price: "$1,850,000",
          beds: 5,
          baths: 4,
          sqft: 3500,
          image: "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&h=600&fit=crop"
        }
      ].map((casa) => (
        <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
          <div class="relative h-56 overflow-hidden">
            <img src={casa.image} alt={casa.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
            <div class="absolute top-4 left-4 bg-white px-3 py-1 rounded-full text-sm font-semibold text-seashell-900">
              En Venta
            </div>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-seashell-900 mb-2">{casa.price}</div>
            <h3 class="text-lg font-semibold text-seashell-800 mb-1">{casa.title}</h3>
            <div class="flex items-center gap-2 text-seashell-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span class="text-sm">{casa.location}</span>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-seashell-100">
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 4v16"></path>
                  <path d="M6 8V4"></path>
                  <path d="M10 12V4"></path>
                  <path d="M14 16V4"></path>
                  <path d="M18 20V4"></path>
                  <path d="M22 8V4"></path>
                </svg>
                <span class="text-sm">{casa.beds} Hab.</span>
              </div>
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20"></path>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                <span class="text-sm">{casa.baths} Baños</span>
              </div>
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                  <path d="M3 9h18"></path>
                  <path d="M9 21V9"></path>
                </svg>
                <span class="text-sm">{casa.sqft} ft²</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
