---

<section class="py-16 px-4 bg-seashell-50">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl font-bold text-seashell-900">Circuito Especial</h2>
      <div class="flex gap-3">
        <button id="scroll-left-especial" class="p-3 rounded-full border border-seashell-300 bg-white transition-all duration-200 hover:bg-seashell-50 hover:border-seashell-400" aria-label="Desplazar a la izquierda">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-700">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
        </button>
        <button id="scroll-right-especial" class="p-3 rounded-full border border-seashell-300 bg-white transition-all duration-200 hover:bg-seashell-50 hover:border-seashell-400" aria-label="Desplazar a la derecha">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-700">
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
      </div>
    </div>
    
    <div 
      id="slider-container-especial"
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4"
      style="scroll-behavior: smooth"
    >
      {[
        {
          title: "Villa con Piscina Infinity",
          location: "Camilo Cienfuegos",
          price: "$3,500,000",
          beds: 5,
          baths: 5,
          sqft: 5200,
          image: "https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop"
        },
        {
          title: "Penthouse de Lujo",
          location: "Nuevo Bayamo",
          price: "$2,800,000",
          beds: 4,
          baths: 4,
          sqft: 3800,
          image: "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=600&fit=crop"
        },
        {
          title: "Casa de Campo Premium",
          location: "San Juan",
          price: "$1,950,000",
          beds: 4,
          baths: 3,
          sqft: 3200,
          image: "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&h=600&fit=crop"
        },
        {
          title: "Residencia Frente al Mar",
          location: "El Cristo",
          price: "$4,200,000",
          beds: 6,
          baths: 6,
          sqft: 6500,
          image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop"
        },
        {
          title: "Loft de Diseñador",
          location: "Jesús Menéndez",
          price: "$1,500,000",
          beds: 3,
          baths: 2,
          sqft: 2100,
          image: "https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde?w=800&h=600&fit=crop"
        },
        {
          title: "Mansión con Jardín",
          location: "Las Caobas",
          price: "$3,100,000",
          beds: 5,
          baths: 5,
          sqft: 4800,
          image: "https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&h=600&fit=crop"
        }
      ].map((casa, index) => (
        <div 
          key={index}
          class="min-w-[320px] max-w-[320px] snap-center flex-shrink-0 bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300"
        >
          <div class="relative h-48 overflow-hidden">
            <img src={casa.image} alt={casa.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
            <div class="absolute top-4 left-4 bg-seashell-900 text-white px-3 py-1 rounded-full text-sm font-semibold">
              Especial
            </div>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-seashell-900 mb-2">{casa.price}</div>
            <h3 class="text-lg font-semibold text-seashell-800 mb-1">{casa.title}</h3>
            <div class="flex items-center gap-2 text-seashell-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span class="text-sm">{casa.location}</span>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-seashell-100">
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 4v16"></path>
                  <path d="M6 8V4"></path>
                  <path d="M10 12V4"></path>
                  <path d="M14 16V4"></path>
                  <path d="M18 20V4"></path>
                  <path d="M22 8V4"></path>
                </svg>
                <span class="text-sm">{casa.beds} Hab.</span>
              </div>
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20"></path>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                <span class="text-sm">{casa.baths} Baños</span>
              </div>
              <div class="flex items-center gap-1 text-seashell-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                  <path d="M3 9h18"></path>
                  <path d="M9 21V9"></path>
                </svg>
                <span class="text-sm">{casa.sqft} ft²</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <style is:global>
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('slider-container-especial');
    const leftBtn = document.getElementById('scroll-left-especial');
    const rightBtn = document.getElementById('scroll-right-especial');
    let autoplayInterval;

    const scrollLeft = () => {
      container.scrollBy({ left: -380, behavior: 'smooth' });
    };

    const scrollRight = () => {
      container.scrollBy({ left: 380, behavior: 'smooth' });
    };

    const checkScrollPosition = () => {
      const { scrollLeft, scrollWidth, clientWidth } = container;
      leftBtn.disabled = scrollLeft <= 10;
      rightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 10;
    };

    const startAutoplay = () => {
      stopAutoplay();
      autoplayInterval = setInterval(() => {
        const { scrollLeft, scrollWidth, clientWidth } = container;
        if (scrollLeft + clientWidth >= scrollWidth - 10) {
          container.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          scrollRight();
        }
      }, 4000);
    };

    const stopAutoplay = () => {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
      }
    };

    leftBtn.addEventListener('click', scrollLeft);
    rightBtn.addEventListener('click', scrollRight);
    container.addEventListener('scroll', checkScrollPosition);
    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);
    container.addEventListener('touchstart', stopAutoplay);
    container.addEventListener('touchend', startAutoplay);

    checkScrollPosition();
    startAutoplay();
  });
</script>
