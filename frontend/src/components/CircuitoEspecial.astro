---
import { supabase } from '../lib/supabase';

const { data: special, error } = await supabase
  .from('properties')
  .select('*')
  .eq('special_circuit', true)
  .limit(6);
---

<section class="py-16 px-4 bg-background">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl font-bold text-foreground">Circuito Especial</h2>
      <div class="flex gap-3">
        <button id="scroll-left-especial" class="p-3 rounded-full border border-border bg-card transition-all duration-200 hover:bg-accent hover:border-border" aria-label="Desplazar a la izquierda">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronLeft" aria-hidden="true"><path d="M14.9 6L12 9l-2.9 3 2.9 3 2.9 3"></path></svg>
        </button>
        <button id="scroll-right-especial" class="p-3 rounded-full border border-border bg-card transition-all duration-200 hover:bg-accent hover:border-border" aria-label="Desplazar a la derecha">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronRight" aria-hidden="true"><path d="M9.1 18l2.9-3 2.9-3L12 9 9.1 6"></path></svg>
        </button>
      </div>
    </div>
    
    <div 
      id="slider-container-especial"
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4"
      style="scroll-behavior: smooth"
    >
      {special?.map((casa, index) => (
        <a 
          href={`/casa/${casa.id}`}
          key={index}
          class="min-w-[320px] max-w-[320px] snap-center flex-shrink-0 bg-card rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 block hover:scale-[1.02] transition-transform"
        >
          <div class="relative h-48 overflow-hidden">
            <img src={casa.main_image_url} alt={casa.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
            <div class="absolute top-4 left-4 bg-primary text-primary-foreground px-3 py-1 rounded-full text-sm font-semibold">
              Especial
            </div>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-foreground mb-2">{casa.price}</div>
            <h3 class="text-lg font-semibold text-foreground mb-1">{casa.title}</h3>
            <div class="flex items-center gap-2 text-muted-foreground mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMapPin" aria-hidden="true"><path d="M17.116 13.391h0L12 21l-5.258-7.8q-.1-.135-.186-.276l-.027-.04h0a6.459 6.459 0 1110.585.505zM12 7.175a2.3 2.3 0 102.3 2.3 2.3 2.3 0 00-2.3-2.3z"></path></svg>
              <span class="text-sm">{casa.location}</span>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-border">
              <div class="flex items-center gap-1 text-muted-foreground">
                 <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor"><path d="M80-200v-240q0-27 11-49t29-39v-112q0-50 35-85t85-35h160q23 0 43 8.5t37 23.5q17-15 37-23.5t43-8.5h160q50 0 85 35t35 85v112q18 17 29 39t11 49v240h-80v-80H160v80H80Zm440-360h240v-80q0-17-11.5-28.5T720-680H560q-17 0-28.5 11.5T520-640v80Zm-320 0h240v-80q0-17-11.5-28.5T400-680H240q-17 0-28.5 11.5T200-640v80Zm-40 200h640v-80q0-17-11.5-28.5T760-480H200q-17 0-28.5 11.5T160-440v80Zm640 0H160h640Z"/></svg>
                <span class="text-sm">{casa.beds} Hab.</span>
              </div>
              <div class="flex items-center gap-1 text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor"><path d="M223.5-623.5Q200-647 200-680t23.5-56.5Q247-760 280-760t56.5 23.5Q360-713 360-680t-23.5 56.5Q313-600 280-600t-56.5-23.5ZM200-80q-17 0-28.5-11.5T160-120q-33 0-56.5-23.5T80-200v-240h120v-30q0-38 26-64t64-26q20 0 37 8t31 22l56 62q8 8 15.5 15t16.5 13h274v-326q0-14-10-24t-24-10q-6 0-11.5 2.5T664-790l-50 50q5 17 2 33.5T604-676L494-788q14-9 30-11.5t32 3.5l50-50q16-16 36.5-25t43.5-9q48 0 81 33t33 81v326h80v240q0 33-23.5 56.5T800-120q0 17-11.5 28.5T760-80H200Zm-40-120h640v-160H160v160Zm0 0h640-640Z"/></svg>
                <span class="text-sm">{casa.baths} Baños</span>
              </div>
              <div class="flex items-center gap-1 text-muted-foreground">
                 <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor"><path d="M208-120q-37 0-62.5-25.5T120-208v-548q0-29 27-40.5t47 8.5l90 90-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 80 80q20 20 8.5 47T756-120H208Zm32-120h332L240-572v332Z"/></svg>
                <span class="text-sm">{casa.sqft} ft²</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <style is:global>
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('slider-container-especial');
    if (!container) return;
    const leftBtn = document.getElementById('scroll-left-especial');
    const rightBtn = document.getElementById('scroll-right-especial');
    let autoplayInterval;

    const scrollLeft = () => {
      container.scrollBy({ left: -380, behavior: 'smooth' });
    };

    const scrollRight = () => {
      container.scrollBy({ left: 380, behavior: 'smooth' });
    };

    const checkScrollPosition = () => {
      if (!container) return;
      const { scrollLeft, scrollWidth, clientWidth } = container;
      leftBtn.disabled = scrollLeft <= 10;
      rightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 10;
    };

    const startAutoplay = () => {
      stopAutoplay();
      autoplayInterval = setInterval(() => {
        if (!container) return;
        const { scrollLeft, scrollWidth, clientWidth } = container;
        if (scrollLeft + clientWidth >= scrollWidth - 10) {
          container.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          scrollRight();
        }
      }, 4000);
    };

    const stopAutoplay = () => {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
      }
    };

    leftBtn.addEventListener('click', scrollLeft);
    rightBtn.addEventListener('click', scrollRight);
    container.addEventListener('scroll', checkScrollPosition);
    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);
    container.addEventListener('touchstart', stopAutoplay);
    container.addEventListener('touchend', startAutoplay);

    checkScrollPosition();
    startAutoplay();
  });
</script>
