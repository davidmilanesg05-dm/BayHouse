<script>
  document.addEventListener('DOMContentLoaded', () => {
    const lines = Array.from(document.querySelectorAll('.house-line'));
    
    // Initialize all lines as hidden
    lines.forEach(line => {
      const length = line.getTotalLength ? line.getTotalLength() : 20;
      line.style.strokeDasharray = length;
      line.style.strokeDashoffset = length;
    });

    // Custom easing function
    const easeOutQuad = (t) => t * (2 - t);
    const easeInQuad = (t) => t * t;

    const animateDrawing = () => {
      let currentLine = 0;
      
      const drawLine = () => {
        if (currentLine >= lines.length) {
          setTimeout(eraseDrawing, 750);
          return;
        }
        
        const line = lines[currentLine];
        const length = line.getTotalLength ? line.getTotalLength() : 20;
        const duration = 150;
        const startTime = performance.now();
        
        const animate = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easedProgress = easeOutQuad(progress);
          
          line.style.strokeDashoffset = length * (1 - easedProgress);
          
          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            currentLine++;
            setTimeout(drawLine, 100);
          }
        };
        
        requestAnimationFrame(animate);
      };
      
      const eraseDrawing = () => {
        let currentErase = lines.length - 1;
        
        const eraseLine = () => {
          if (currentErase < 0) {
            setTimeout(animateDrawing, 750);
            return;
          }
          
          const line = lines[currentErase];
          const length = line.getTotalLength ? line.getTotalLength() : 20;
          const duration = 100;
          const startTime = performance.now();
          
          const animate = (currentTime) => {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const easedProgress = easeInQuad(progress);
            
            line.style.strokeDashoffset = length * easedProgress;
            
            if (progress < 1) {
              requestAnimationFrame(animate);
            } else {
              currentErase--;
              setTimeout(eraseLine, 100);
            }
          };
          
          requestAnimationFrame(animate);
        };
        
        eraseLine();
      };
      
      drawLine();
    };
    
    animateDrawing();
  });
</script>
