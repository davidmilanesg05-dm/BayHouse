---
---
<header class="flex justify-between items-center p-4 bg-background border-b border-border fixed top-0 left-0 right-0 z-[1000]">
  <div>
    <a href="/" class="text-2xl font-bold text-foreground no-underline">BAYHOUSE</a>
  </div>
  <div class="flex items-center gap-4">
    <button id="themeToggle" class="p-2 rounded-full hover:bg-muted transition-colors">
      <!-- Sun icon (light mode) -->
      <svg id="sunIcon" class="w-6 h-6 hidden dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon icon (dark mode) -->
      <svg id="moonIcon" class="w-6 h-6 block dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
    <button id="menuToggle" class="bg-transparent border-none text-2xl cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMenu" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"></path></svg>
    </button>
  </div>
</header>

<!-- Sidebar Overlay -->
<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-[1001]"></div>

<!-- Sidebar Menu -->
<aside id="sidebar" class="fixed top-0 left-0 h-full w-72 bg-background border-r border-border z-[1002] flex flex-col">
  <div class="flex justify-between items-center p-4 border-b border-border">
    <a href="/" class="text-2xl font-bold text-foreground no-underline" id="sidebarLogo">BAYHOUSE</a>
    <button id="sidebarClose" class="p-2 rounded-full hover:bg-muted transition-colors">
      
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgX" aria-hidden="true"><path d="M5.636 5.636l12.728 12.728m-12.728 0L18.364 5.636m0 0"></path></svg>
    </button>
  </div>
  <nav class="flex-1 p-4 space-y-2">
    <a href="/" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgHome" aria-hidden="true"><path d="M4.75 10.75v9a1.16 1.16 0 00.213.725.717.717 0 00.587.275h12.4a.737.737 0 00.55-.275 1.1 1.1 0 00.25-.725v-9m-16 2l4.5-5 4.5-5 4.5 5 4.5 5m-11.5 8v-5a.945.945 0 011-1h3a.945.945 0 011 1v5"></path></svg>
      Inicio
    </a>
    <a href="/propiedades" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="10" width="24" height="24" viewBox="0 0 24 24" data-icon="SvgOfficeBuilding" aria-hidden="true"><path d="M9 15.25h0m3 0h0m3 0h0m-6-3h0m3 0h0m3 0h0m-6-3h0m3 0h0m3 0h0m-6-3h0m3 0h0m3 0h0m-3 13v2.656"></path><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect></svg>
      Propiedades
    </a>
    <a href="/favoritos" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgHeart" aria-hidden="true"><path d="M19.616 5.673a4.738 4.738 0 00-6.7 0L12 6.586l-.913-.913a4.739 4.739 0 00-6.7 6.7l.913.913 6.7 6.7 6.7-6.7.913-.913a4.738 4.738 0 000-6.7z"></path></svg>
      Favoritos
    </a>
    <a href="/about" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgUsers" aria-hidden="true"><path d="M12.1 3.8a3.4 3.4 0 011.037-.588A3.786 3.786 0 0114.4 3a3.5 3.5 0 010 7 3.761 3.761 0 01-1.263-.213A3.378 3.378 0 0112.1 9.2M16.2 21H21a8.881 8.881 0 00-1.95-5.65A6.074 6.074 0 0014.4 13a5.683 5.683 0 00-1.038.088 3.6 3.6 0 00-.962.312M9.6 3a3.5 3.5 0 11-2.475 1.025A3.493 3.493 0 019.6 3zm6.6 18a8.881 8.881 0 00-1.95-5.65A6.074 6.074 0 009.6 13h0a6.074 6.074 0 00-4.65 2.35A8.881 8.881 0 003 21h13.2z"></path></svg>
      Sobre Nosotros
    </a>
    <a href="/contact" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMail" aria-hidden="true"><path d="M3 5.75h18v12.5H3V5.75zm0 0l3.9 3 3.9 3a2.107 2.107 0 002.4 0l3.9-3 3.9-3"></path></svg>
      Contacto
    </a>
    <div class="border-t border-border my-4"></div>
    <a href="/faq" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
      FAQ
    </a>
    <a href="/politicas" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgShield" aria-hidden="true"><path d="M12 20.957c-4.347-2.37-7.143-6.031-7.158-10.144h0V5.847L12 3.043l7.162 2.8v4.966h0c-.021 4.117-2.816 7.778-7.162 10.148z"></path></svg>
      Políticas de Privacidad
    </a>
    <a href="/terminos" class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition-colors text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgFileText" aria-hidden="true"><path d="M13.15 2.75h-7.3a.95.95 0 00-1 .89v16.11c-.03.52.37.97.89 1h11.91a.95.95 0 001-.89V8.25h-5.5v-5.5zm0 0L15.9 5.5l2.75 2.75m-9.9 4.3h6m-6 3.8h6m-4.86-7.8H8.75"></path></svg>
      Términos y Condiciones
    </a>
  </nav>
</aside>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('themeToggle');
    const menuToggle = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const sidebarClose = document.getElementById('sidebarClose');
    const sidebarLogo = document.getElementById('sidebarLogo');
    const sidebarLinks = document.querySelectorAll('#sidebar a');
    const sidebarCloseBtn = document.getElementById('sidebarClose');
    
    // Set initial state for animations
    gsap.set(sidebar, { x: -320 });
    gsap.set(sidebarOverlay, { opacity: 0, display: 'none' });
    gsap.set([sidebarLogo, sidebarCloseBtn, ...sidebarLinks], { opacity: 0, x: -30 });
    
    // Theme Toggle
    if (toggleBtn) {
      function toggleTheme() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }
      toggleBtn.addEventListener('click', toggleTheme);
    }
    
    // Sidebar Toggle with GSAP animations
    function openSidebar() {
      document.body.style.overflow = 'hidden';
      
      const tl = gsap.timeline();
      
      tl.to(sidebarOverlay, { 
        display: 'block', 
        opacity: 1, 
        duration: 0.3, 
        ease: 'power2.out' 
      })
      .to(sidebar, { 
        x: 0, 
        duration: 0.4, 
        ease: 'power3.out' 
      }, '-=0.2')
      .to([sidebarLogo, sidebarCloseBtn], { 
        opacity: 1, 
        x: 0, 
        duration: 0.3, 
        stagger: 0.1, 
        ease: 'power2.out' 
      }, '-=0.2')
      .to(sidebarLinks, { 
        opacity: 1, 
        x: 0, 
        duration: 0.4, 
        stagger: 0.08, 
        ease: 'power2.out' 
      }, '-=0.2');
    }
    
    function closeSidebar() {
      const tl = gsap.timeline();
      
      tl.to([...sidebarLinks].reverse(), { 
        opacity: 0, 
        x: -30, 
        duration: 0.3, 
        stagger: 0.05, 
        ease: 'power2.in' 
      })
      .to([sidebarCloseBtn, sidebarLogo], { 
        opacity: 0, 
        x: -30, 
        duration: 0.2, 
        stagger: 0.05, 
        ease: 'power2.in' 
      }, '-=0.1')
      .to(sidebar, { 
        x: -320, 
        duration: 0.35, 
        ease: 'power3.in' 
      }, '-=0.1')
      .to(sidebarOverlay, { 
        opacity: 0, 
        display: 'none', 
        duration: 0.3, 
        ease: 'power2.in', 
        onComplete: () => {
          document.body.style.overflow = '';
        }
      }, '-=0.25');
    }
    
    if (menuToggle) {
      menuToggle.addEventListener('click', openSidebar);
    }
    
    if (sidebarClose) {
      sidebarClose.addEventListener('click', closeSidebar);
    }
    
    if (sidebarOverlay) {
      sidebarOverlay.addEventListener('click', closeSidebar);
    }
    
    if (sidebarLogo) {
      sidebarLogo.addEventListener('click', closeSidebar);
    }
    
    sidebarLinks.forEach(link => {
      link.addEventListener('click', closeSidebar);
      
      // Add hover animation to links
      link.addEventListener('mouseenter', () => {
        gsap.to(link, { x: 8, duration: 0.2, ease: 'power2.out' });
      });
      link.addEventListener('mouseleave', () => {
        gsap.to(link, { x: 0, duration: 0.2, ease: 'power2.out' });
      });
    });
  });
</script>
