---
---

<section id="cta-section" class="py-20 px-4 bg-background">
  <div class="max-w-5xl mx-auto">
    <h2 id="cta-title" class="text-3xl font-bold text-foreground mb-12 text-center">¿Qué estás buscando?</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Vender Card -->
      <div class="cta-card bg-card p-8 rounded-2xl shadow-xl border border-border hover:shadow-2xl transition-shadow duration-300">
        <div class="flex flex-col items-center text-center">
          <div class="cta-icon w-20 h-20 bg-muted rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgDollarSign" aria-hidden="true"><path d="M12 3a9 9 0 11-6.364 2.636A8.972 8.972 0 0112 3zm2.1 6.1a2.083 2.083 0 00-.863-.813A2.7 2.7 0 0012 8a2.656 2.656 0 00-1.687.587 1.8 1.8 0 00-.363 2.5 2.045 2.045 0 00.95.712 4.255 4.255 0 001.35.312 3.318 3.318 0 011.35.388 2.3 2.3 0 01.588.675A1.693 1.693 0 0114.4 14a1.848 1.848 0 01-.712 1.413 2.743 2.743 0 01-3.013.25A2.325 2.325 0 019.8 14.8M12 16v1.7m0-11.4V8"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-foreground mb-4">¿Quieres vender tu casa?</h3>
          <p class="text-muted-foreground mb-8">Conecta con los mejores agentes y vende tu propiedad rápido al mejor precio del mercado.</p>
          <a href="/contact">
            <button class="bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:bg-primary/90 transition-colors duration-300 flex items-center gap-2">
              <span>Contactar para vender</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronRight" aria-hidden="true"><path d="M9.1 18l2.9-3 2.9-3L12 9 9.1 6"></path></svg>
            </button>
          </a>
        </div>
      </div>
      
      <!-- Buscar Card -->
      <div class="cta-card bg-card p-8 rounded-2xl shadow-xl border border-border hover:shadow-2xl transition-shadow duration-300">
        <div class="flex flex-col items-center text-center">
          <div class="cta-icon w-20 h-20 bg-muted rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgSearch" aria-hidden="true"><path d="M10.1 3a7.1 7.1 0 11-5.02 2.08A7.074 7.074 0 0110.1 3zM21 21l-2.9-2.9-2.9-2.9"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-foreground mb-4">¿Qué estás buscando?</h3>
          <p class="text-muted-foreground mb-8">Cuéntanos qué características necesitas en tu casa ideal y nosotros te ayudamos a encontrarla.</p>
          <a href="/contact">
            <button class="bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:bg-primary/90 transition-colors duration-300 flex items-center gap-2">
              <span>Rellenar formulario</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronRight" aria-hidden="true"><path d="M9.1 18l2.9-3 2.9-3L12 9 9.1 6"></path></svg>
            </button>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener('DOMContentLoaded', () => {
    const title = document.getElementById('cta-title');
    const cards = document.querySelectorAll('.cta-card');
    
    if (title) {
      gsap.fromTo(title, 
        { opacity: 0, y: 40 }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.8, 
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '#cta-section',
            start: 'top 80%'
          }
        }
      );
    }
    
    if (cards.length > 0) {
      gsap.fromTo(cards, 
        { opacity: 0, y: 50 }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.7, 
          stagger: 0.2, 
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '#cta-section',
            start: 'top 75%'
          }
        }
      );
      
      // Add hover animations
      cards.forEach(card => {
        card.addEventListener('mouseenter', () => {
          gsap.to(card, { y: -10, scale: 1.02, duration: 0.3, ease: 'power2.out' });
        });
        card.addEventListener('mouseleave', () => {
          gsap.to(card, { y: 0, scale: 1, duration: 0.3, ease: 'power2.out' });
        });
      });
    }
  });
</script>
