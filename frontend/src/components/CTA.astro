---
---

<section class="py-20 px-4 bg-seashell-50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-seashell-900 mb-12 text-center">¿Qué estás buscando?</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Vender Card -->
      <div class="bg-white p-8 rounded-2xl shadow-xl border border-seashell-100 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex flex-col items-center text-center">
          <div class="w-20 h-20 bg-seashell-100 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-700">
              <path d="M12 3a9 9 0 11-6.364 2.636A8.972 8.972 0 0112 3zm2.1 6.1a2.083 2.083 0 00-.863-.813A2.7 2.7 0 0012 8a2.656 2.656 0 00-1.687.587 1.8 1.8 0 00-.363 2.5 2.045 2.045 0 00.95.712 4.255 4.255 0 001.35.312 3.318 3.318 0 011.35.388 2.3 2.3 0 01.588.675A1.693 1.693 0 0114.4 14a1.848 1.848 0 01-.712 1.413 2.743 2.743 0 01-3.013.25A2.325 2.325 0 019.8 14.8M12 16v1.7m0-11.4V8"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-seashell-900 mb-4">¿Quieres vender tu casa?</h3>
          <p class="text-seashell-600 mb-8">Conecta con los mejores agentes y vende tu propiedad rápido al mejor precio del mercado.</p>
          <button class="bg-seashell-900 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-seashell-800 transition-colors duration-300 flex items-center gap-2">
            <span>Contactar para vender</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Buscar Card -->
      <div class="bg-white p-8 rounded-2xl shadow-xl border border-seashell-100 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex flex-col items-center text-center">
          <div class="w-20 h-20 bg-seashell-100 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-700">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-seashell-900 mb-4">¿Qué estás buscando?</h3>
          <p class="text-seashell-600 mb-8">Cuéntanos qué características necesitas en tu casa ideal y nosotros te ayudamos a encontrarla.</p>
          <button class="bg-seashell-900 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-seashell-800 transition-colors duration-300 flex items-center gap-2">
            <span>Rellenar formulario</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
