---
---

<section class="py-16 px-4 bg-background">
  <div class="max-w-6xl mx-auto">    
    <!-- Single Image Ad -->
    <div class="mb-12 rounded-xl overflow-hidden shadow-lg">
      <img 
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&h=500&fit=crop" 
        alt="Negocios Asociados" 
        class="w-full h-64 md:h-80 object-cover hover:scale-105 transition-transform duration-500"
      />
    </div>
    
    <!-- CTA Card -->
    <div class="bg-gradient-to-r from-primary to-primary/80 rounded-2xl p-8 md:p-12 text-center">
      <h3 class="text-2xl md:text-3xl font-bold text-primary-foreground mb-4">¿Quieres anunciar tu negocio?</h3>
      <p class="text-primary-foreground/80 mb-8 max-w-2xl mx-auto">Únete a nuestra red de negocios asociados y llega a miles de clientes potenciales.</p>
      <a href="https://wa.me/+5354776027?text=Hola,%20estoy%20interesado%20en%20promocionar%20mi%20negocio/producto%20en%20su%20pagina%20web" target="_blank">
        <button class="bg-card text-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:bg-muted transition-colors duration-300 inline-flex items-center gap-2">
          <span>Solicitar Anuncio</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronRight" aria-hidden="true"><path d="M9.1 18l2.9-3 2.9-3L12 9 9.1 6"></path></svg>
        </button>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener('DOMContentLoaded', () => {
    const adImage = document.querySelector('.mb-12');
    const ctaCard = document.querySelector('.bg-gradient-to-r');
    
    if (adImage) {
      gsap.fromTo(adImage, 
        { opacity: 0, y: 40 }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.8, 
          ease: 'power2.out',
          scrollTrigger: {
            trigger: adImage,
            start: 'top 85%'
          }
        }
      );
    }
    
    if (ctaCard) {
      gsap.fromTo(ctaCard.children, 
        { opacity: 0, y: 30 }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.7, 
          stagger: 0.15, 
          ease: 'power2.out',
          scrollTrigger: {
            trigger: ctaCard,
            start: 'top 85%'
          }
        }
      );
    }
  });
</script>
