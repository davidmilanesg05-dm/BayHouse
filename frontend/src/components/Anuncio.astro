---
---

<section class="py-16 px-4 bg-seashell-50">
  <div class="max-w-6xl mx-auto">    
    <!-- Single Image Ad -->
    <div class="mb-12 rounded-xl overflow-hidden shadow-lg">
      <img 
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&h=500&fit=crop" 
        alt="Negocios Asociados" 
        class="w-full h-64 md:h-80 object-cover hover:scale-105 transition-transform duration-500"
      />
    </div>
    
    <!-- CTA Card -->
    <div class="bg-gradient-to-r from-seashell-900 to-seashell-800 rounded-2xl p-8 md:p-12 text-center">
      <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">¿Quieres anunciar tu negocio?</h3>
      <p class="text-seashell-200 mb-8 max-w-2xl mx-auto">Únete a nuestra red de negocios asociados y llega a miles de clientes potenciales.</p>
      <button class="bg-white text-seashell-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-seashell-100 transition-colors duration-300 inline-flex items-center gap-2">
        <span>Solicitar Anuncio</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"></path>
        </svg>
      </button>
    </div>
  </div>
</section>
