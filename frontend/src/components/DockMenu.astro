<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const dock = document.getElementById('dock');
    const items = Array.from(document.querySelectorAll('.dock-item')) as HTMLElement[];

    dock?.addEventListener('mousemove', (e) => {
      const dockRect = dock.getBoundingClientRect();
      const mouseX = e.clientX - dockRect.left;

      items.forEach((item) => {
        const itemRect = item.getBoundingClientRect();
        const itemX = itemRect.left - dockRect.left + itemRect.width / 2;
        const distance = Math.abs(mouseX - itemX);

        // Adjust scale based on distance, max scale 1.5
        const scale = Math.max(1, 1.5 - distance / 100);
        gsap.to(item, { scale: scale, duration: 0.2, ease: 'power2.out' });
      });
    });

    dock?.addEventListener('mouseleave', () => {
      gsap.to(items, { scale: 1, duration: 0.2, ease: 'power2.out' });
    });
  });
</script>