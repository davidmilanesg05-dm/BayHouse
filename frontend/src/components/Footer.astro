          <li class="flex items-center gap-3 text-seashell-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMail" aria-hidden="true"><path d="M3 5.75h18v12.5H3V5.75zm0 0l3.9 3 3.9 3a2.107 2.107 0 002.4 0l3.9-3 3.9-3"></path></svg>
