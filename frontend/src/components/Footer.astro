<footer class="bg-seashell-900 text-white pt-16 pb-8 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Logo & About -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          
          <img src="/logo.png" width="40px" height="40px" alt="">
          <span class="text-2xl font-bold">BayHouse</span>
        </div>
        <p class="text-seashell-400 mb-6">Tu socio de confianza para encontrar la casa de tus sueños. Conectamos a compradores y vendedores con confianza y seguridad.</p>
        <!-- Social Media -->
        <div class="flex gap-4">
          <button class="w-10 h-10 bg-seashell-800 rounded-full flex items-center justify-center hover:bg-seashell-700 transition-colors" onclick="alert('No tenemos redes sociales disponibles aún, pero puedes contactarnos por WhatsApp o correo!')">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-seashell-300">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
