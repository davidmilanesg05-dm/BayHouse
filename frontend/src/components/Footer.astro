      <!-- Contacto -->
      <div>
        <h3 class="text-lg font-semibold mb-6 text-white">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-seashell-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMap" aria-hidden="true"><path d="M3 7.091v13.091l5.727-3.273 6.546 3.273L21 16.909V3.818l-5.727 3.273-6.546-3.273zm5.727 1.727v8.091m6.546-9.818v12.091"></path></svg>
            <span>Presencia Online</span>
          </li>
          <li class="flex items-center gap-3 text-seashell-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgPhoneCall" aria-hidden="true"><path d="M14.173 6.147a3.681 3.681 0 013.68 3.68M21 9.993A6.993 6.993 0 0014.007 3m-3.386 9.717A18.541 18.541 0 018.5 9.463l.987-.481a1.32 1.32 0 00.7-1.5c-.38-1.532-.5-2.06-.768-3.415a1.318 1.318 0 00-1.56-1.04l-3.186.655A2.067 2.067 0 003.014 5.9a17.054 17.054 0 0015.073 15.088 2.065 2.065 0 002.224-1.674l.662-3.352a1.319 1.319 0 00-1.063-1.55c-1.261-.225-2.071-.454-3.316-.781a1.315 1.315 0 00-1.535.741l-.7 1.576"></path></svg>
