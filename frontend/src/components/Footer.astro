          <button class="w-10 h-10 bg-seashell-800 rounded-full flex items-center justify-center hover:bg-seashell-700 transition-colors" onclick="alert('No tenemos redes sociales disponibles aún, pero puedes contactarnos por WhatsApp o correo!')">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-seashell-300">
