          </li>
        </ul>
      </div>
    
    <!-- Bottom -->
    <div class="border-t border-seashell-800 pt-8 pb-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-seashell-500 text-sm">© 2026 BayHouse. Todos los derechos reservados.</p>
        <div class="flex gap-6 text-sm">
          <a href="/faq" class="text-seashell-500 hover:text-white transition-colors">Preguntas frecuentes</a>
          <a href="/terminos" class="text-seashell-500 hover:text-white transition-colors">Términos de Uso</a>
          <a href="/politicas" class="text-seashell-500 hover:text-white transition-colors">Política de Privacidad</a>
        </div>
      </div>
    </div>
  </div>
</footer>
