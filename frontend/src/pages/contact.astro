---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="bg-seashell-50 text-seashell-900 min-h-screen">
    <!-- Back Button -->
    <section class="pt-8 px-4">
      <div class="max-w-7xl mx-auto">
        <a href="/" class="flex items-center gap-2 text-seashell-600 hover:text-seashell-900 transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="font-semibold">Volver</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Contáctanos</h1>
        <p class="text-xl md:text-2xl text-seashell-600 max-w-3xl mx-auto">¿Listo para encontrar tu hogar ideal? ¡Nos encantaría ayudarte!</p>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-3xl font-bold mb-8">Información de Contacto</h2>
            
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">Dirección</h3>
                  <p class="text-seashell-600">Calle Principal #123, Bayamo, Cuba</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">Teléfono</h3>
                  <p class="text-seashell-600">+53 555-1234</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">Email</h3>
                  <p class="text-seashell-600">info@bayhouse.com</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">Horario</h3>
                  <p class="text-seashell-600">Lunes a Viernes: 9:00 AM - 6:00 PM</p>
                  <p class="text-seashell-600">Sábados: 9:00 AM - 1:00 PM</p>
                </div>
              </div>
            </div>

            <!-- Social Links -->
            <div class="mt-10">
              <h3 class="font-bold text-lg mb-4">Síguenos</h3>
              <div class="flex gap-4">
                <a href="#" class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center hover:bg-seashell-200 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-seashell-700">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
                <a href="#" class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center hover:bg-seashell-200 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-seashell-700">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                </a>
                <a href="#" class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center hover:bg-seashell-200 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-seashell-700">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <h2 class="text-3xl font-bold mb-8">Envíanos un mensaje</h2>
            
            <form class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold mb-2">Nombre</label>
                  <input 
                    type="text" 
                    class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                    placeholder="Tu nombre"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold mb-2">Teléfono</label>
                  <input 
                    type="tel" 
                    class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                    placeholder="Tu teléfono"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Email</label>
                <input 
                  type="email" 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  placeholder="tu@email.com"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Asunto</label>
                <select class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent bg-white">
                  <option>Selecciona un asunto</option>
                  <option>Comprar propiedad</option>
                  <option>Vender propiedad</option>
                  <option>Alquilar propiedad</option>
                  <option>Consulta general</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Mensaje</label>
                <textarea 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  rows="6"
                  placeholder="Escribe tu mensaje aquí..."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full bg-seashell-600 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-seashell-700 transition-colors"
              >
                Enviar Mensaje
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Placeholder -->
    <section class="py-16 px-4 bg-seashell-100">
      <div class="max-w-7xl mx-auto">
        <div class="bg-seashell-200 rounded-2xl h-96 flex items-center justify-center">
          <div class="text-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600 mx-auto mb-4">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <p class="text-seashell-700 text-lg font-semibold">Mapa de ubicación</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>