---
import Layout from '../layouts/Layout.astro';
import NumberCounter from '../components/NumberFlowCounter';
---

<Layout>
  <main class="bg-background text-foreground min-h-screen">
    <!-- Back Button -->
    <section class="pt-8 px-4">
      <div class="max-w-7xl mx-auto">
        <a href="/" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="font-semibold">Volver</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Sobre <span class="text-primary">BayHouse</span></h1>
        <p class="text-xl md:text-2xl text-muted-foreground max-w-3xl mx-auto">Tu inmobiliaria de confianza en Bayamo, conectando personas con sus hogares soñados.</p>
      </div>
    </section>

    <!-- About Content -->
    <section class="py-16 px-4 bg-card">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <img 
              src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&h=600&fit=crop" 
              alt="Nuestra Oficina" 
              class="rounded-2xl shadow-xl w-full"
            >
          </div>
          <div>
            <h2 class="text-3xl font-bold mb-6 text-center">Nuestra Historia</h2>
            <p class="text-muted-foreground mb-4 text-lg">
              BayHouse nació con la misión de transformar la experiencia de comprar y vender propiedades en Bayamo. 
              Fundada por un grupo de profesionales apasionados por el sector inmobiliario.
            </p>
            <p class="text-muted-foreground mb-4 text-lg">
              A lo largo de los años, hemos ayudado a cientos de familias a encontrar su hogar ideal y a vender sus propiedades 
              al mejor precio del mercado.
            </p>
            <p class="text-muted-foreground text-lg">
              Nuestro compromiso con la excelencia y la atención personalizada nos ha convertido en la inmobiliaria 
              de referencia en toda la región.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-16 px-4 bg-background">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Nuestros Valores</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            {
              icon: "shield",
              title: "Confianza",
              description: "Transparencia y honestidad en cada transacción inmobiliaria."
            },
            {
              icon: "users",
              title: "Clientes Primero",
              description: "Tu satisfacción es nuestra prioridad número uno."
            },
            {
              icon: "target",
              title: "Excelencia",
              description: "Buscamos la perfección en cada servicio que ofrecemos."
            }
          ].map((value) => (
            <div class="bg-card p-8 rounded-2xl shadow-lg text-center border border-border">
              <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-6">
                {value.icon === "shield" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgShield" aria-hidden="true" class="text-muted-foreground"><path d="M12 20.957c-4.347-2.37-7.143-6.031-7.158-10.144h0V5.847L12 3.043l7.162 2.8v4.966h0c-.021 4.117-2.816 7.778-7.162 10.148z"></path></svg>
                )}
                {value.icon === "users" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgUsers" aria-hidden="true" class="text-muted-foreground"><path d="M12.1 3.8a3.4 3.4 0 011.037-.588A3.786 3.786 0 0114.4 3a3.5 3.5 0 010 7a3.761 3.761 0 01-1.263-.213A3.378 3.378 0 0112.1 9.2M16.2 21H21a8.881 8.881 0 00-1.95-5.65A6.074 6.074 0 0014.4 13a5.683 5.683 0 00-1.038.088 3.6 3.6 0 00-.962.312M9.6 3a3.5 3.5 0 11-2.475 1.025A3.493 3.493 0 019.6 3zm6.6 18a8.881 8.881 0 00-1.95-5.65A6.074 6.074 0 009.6 13h0a6.074 6.074 0 00-4.65 2.35A8.881 8.881 0 003 21h13.2z"></path></svg>
                )}
                {value.icon === "target" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgTarget" aria-hidden="true" class="text-muted-foreground"><path d="M13.776 12A1.776 1.776 0 1112 10.224 1.776 1.776 0 0113.776 12zM12 6.736A5.264 5.264 0 1017.264 12A5.264 5.264 0 0012 6.736zM12 3a9 9 0 109 9a9 9 0 00-9-9z"></path></svg>
                )}
              </div>
              <h3 class="text-xl font-bold mb-3">{value.title}</h3>
              <p class="text-muted-foreground">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-16 px-4 bg-primary text-primary-foreground">
      <div class="max-w-7xl mx-auto">
        <div id="counter-root" class="grid md:grid-cols-4 gap-8 text-center">
          {[
            { target: 100, suffix: "+", label: "Propiedades Vendidas" },
            { target: 100, suffix: "+", label: "Transacciones Exitosas" },
            { target: 250, suffix: "+", label: "Clientes Satisfechos" },
            { target: 4, suffix: "", label: "Agentes Profesionales" }
          ].map((stat, index) => (
            <div key={index}>
              <NumberCounter
                target={stat.target}
                suffix={stat.suffix}
                className="text-5xl font-bold mb-2 text-primary-foreground/80"
                client:load
              />
              <div class="text-primary-foreground/70">{stat.label}</div>
            </div>
          ))}
        </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 px-4 bg-card">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Lo que dicen nuestros clientes</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            {
              name: "Ana Martínez",
              role: "Compradora de Casa",
              comment: "BayHouse me ayudó a encontrar la casa perfecta para mi familia. El proceso fue súper fácil y los agentes muy profesionales.",
              image: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&h=400&fit=crop"
            },
            {
              name: "Roberto López",
              role: "Vendedor",
              comment: "Vendí mi propiedad en tiempo récord gracias a BayHouse. Obtuvimos un precio excelente y el servicio fue impecable.",
              image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=400&fit=crop"
            },
            {
              name: "Laura Castillo",
              role: "Inversionista",
              comment: "Como inversionista, he trabajado con varias inmobiliarias y BayHouse es sin duda la mejor. ¡Totalmente recomendados!",
              image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&h=400&fit=crop"
            }
          ].map((testimonial) => (
            <div class="bg-background p-8 rounded-2xl shadow-lg border border-border">
              <div class="flex items-center gap-4 mb-6">
                <img 
                  src={testimonial.image} 
                  alt={testimonial.name} 
                  class="w-16 h-16 rounded-full object-cover"
                >
                <div>
                  <h3 class="text-lg font-bold">{testimonial.name}</h3>
                  <p class="text-muted-foreground text-sm">{testimonial.role}</p>
                </div>
              </div>
              <p class="text-foreground/80 text-lg italic">"{testimonial.comment}"</p>
              <div class="flex gap-1 mt-4">
                {[1, 2, 3, 4, 5].map((star) => (
                  <svg key={star} xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#f59e0b" stroke="#f59e0b" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgStar" aria-hidden="true"><path d="M12 3.44l2.781 5.636 6.219.9-4.5 4.387 1.062 6.194L12 17.635 6.438 20.56 7.5 14.366 3 9.979l6.219-.9z"></path></svg>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-4 bg-background">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-6">¿Listo para encontrar tu hogar ideal?</h2>
        <p class="text-muted-foreground mb-8 text-lg">Contáctanos hoy y déjanos ayudarte en tu camino hacia el hogar de tus sueños.</p>
        <a 
          href="/contact" 
          class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:bg-primary/90 transition-colors"
        >
          Contactarnos
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgChevronRight" aria-hidden="true"><path d="M9.1 18l2.9-3 2.9-3L12 9 9.1 6"></path></svg>
        </a>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener('DOMContentLoaded', () => {
    // Hero section
    const heroTitle = document.querySelector('h1');
    const heroSubtitle = document.querySelector('h1 + p');
    
    if (heroTitle) {
      gsap.fromTo(heroTitle, { opacity: 0, y: 50 }, { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
    }
    if (heroSubtitle) {
      gsap.fromTo(heroSubtitle, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: 'power2.out' });
    }
    
    // About content
    const aboutSections = document.querySelectorAll('section');
    aboutSections.forEach((section, index) => {
      if (index > 1) { // Skip back button and hero
        gsap.fromTo(section.children, 
          { opacity: 0, y: 40 }, 
          { 
            opacity: 1, 
            y: 0, 
            duration: 0.8, 
            stagger: 0.15, 
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 80%'
            }
          }
        );
      }
    });
  });
</script>