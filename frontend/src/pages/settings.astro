---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="bg-seashell-50 text-seashell-900 min-h-screen">
    <!-- Back Button -->
    <section class="pt-16 px-4">
      <div class="max-w-4xl mx-auto">
        <a href="/" class="flex items-center gap-2 text-seashell-600 hover:text-seashell-900 transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="font-semibold">Volver</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold mb-2">Ajustes</h1>
        <p class="text-xl text-seashell-600">Personaliza tu experiencia en la página web</p>
      </div>
    </section>

    <!-- Settings Content -->
    <section class="pb-16 px-4">
      <div class="max-w-4xl mx-auto space-y-8">
        <!-- Appearance Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold">Apariencia</h2>
          </div>
          
          <div class="space-y-6">
            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Modo oscuro</h3>
                <p class="text-sm text-seashell-600">Activa el tema oscuro para mayor comodidad visual</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Tamaño de fuente</h3>  -
                <p class="text-sm text-seashell-600">Ajusta el tamaño del texto en la página</p>
              </div>
              <select class="px-4 py-2 border border-seashell-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-seashell-500">
                <option>Pequeño</option>
                <option selected>Mediano</option>
                <option>Grande</option>
              </select>
            </div>

            <div class="flex items-center justify-between py-4">
              <div>
                <h3 class="font-semibold">Animaciones</h3>
                <p class="text-sm text-seashell-600">Activa las animaciones y transiciones</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Property Preferences Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <h2 class="text-2xl font-bold">Preferencias de Propiedades</h2>
          </div>
          
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-semibold mb-2">Ubicación preferida</label>
              <select class="w-full px-4 py-3 border border-seashell-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-seashell-500">
                <option>Todas las ubicaciones</option>
                <option>Camilo Cienfuegos</option>
                <option>Nuevo Bayamo</option>
                <option>San Juan</option>
                <option>El Cristo</option>
                <option>Jesús Menéndez</option>
              </select>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-2">Precio mínimo</label>
                <input 
                  type="number" 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  placeholder="$0"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2">Precio máximo</label>
                <input 
                  type="number" 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  placeholder="$10,000,000"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-2">Habitaciones mínimas</label>
                <input 
                  type="number" 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  placeholder="1"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2">Baños mínimos</label>
                <input 
                  type="number" 
                  class="w-full px-4 py-3 border border-seashell-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-seashell-500 focus:border-transparent"
                  placeholder="1"
                />
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-t border-seashell-100">
              <div>
                <h3 class="font-semibold">Solo propiedades destacadas</h3>
                <p class="text-sm text-seashell-600">Muestra solo propiedades etiquetadas como destacadas</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <button class="w-full bg-seashell-600 text-white px-8 py-3 rounded-xl font-semibold hover:bg-seashell-700 transition-colors">
              Guardar preferencias
            </button>
          </div>
        </div>

        <!-- Notifications Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold">Notificaciones</h2>
          </div>
          
          <div class="space-y-6">
            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Alertas de nuevas propiedades</h3>
                <p class="text-sm text-seashell-600">Recibe notificaciones cuando se agreguen nuevas propiedades</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Actualizaciones de precio</h3>
                <p class="text-sm text-seashell-600">Notifica cuando haya cambios de precio en propiedades</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Boletín semanal</h3>
                <p class="text-sm text-seashell-600">Las mejores propiedades de la semana</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4">
              <div>
                <h3 class="font-semibold">Noticias y actualizaciones</h3>
                <p class="text-sm text-seashell-600">Información sobre nuevas funcionalidades de la página</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Privacy & Cookies Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold">Privacidad y Cookies</h2>
          </div>
          
          <div class="space-y-6">
            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Cookies esenciales</h3>
                <p class="text-sm text-seashell-600">Cookies necesarias para el funcionamiento básico del sitio</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked disabled />
                <div class="w-12 h-7 bg-seashell-400 rounded-full"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Cookies de análisis</h3>
                <p class="text-sm text-seashell-600">Ayúdanos a mejorar la página con datos anónimos</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-seashell-100">
              <div>
                <h3 class="font-semibold">Cookies de personalización</h3>
                <p class="text-sm text-seashell-600">Recuerda tus preferencias y configuraciones</p>
              </div>
              <div class="relative">
                <input type="checkbox" class="sr-only peer" checked />
                <div class="w-12 h-7 bg-seashell-200 rounded-full peer peer-checked:bg-seashell-600 transition-colors"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
            </div>

            <div class="space-y-4 pt-6 border-t border-seashell-100">
              <button class="w-full py-4 text-left px-6 bg-seashell-50 hover:bg-seashell-100 rounded-xl font-semibold transition-colors flex items-center justify-between">
                <span>Ver política de privacidad</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>

              <button class="w-full py-4 text-left px-6 bg-seashell-50 hover:bg-seashell-100 rounded-xl font-semibold transition-colors flex items-center justify-between">
                <span>Ver política de cookies</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>

              <button class="w-full py-4 text-left px-6 bg-seashell-50 hover:bg-seashell-100 rounded-xl font-semibold transition-colors flex items-center justify-between">
                <span>Ver términos de uso</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Data & Storage Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-seashell-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
              </svg>
            </div>
            <h2 class="text-2xl font-bold">Datos y Almacenamiento</h2>
          </div>
          
          <div class="space-y-6">
            <button class="w-full py-4 text-left px-6 bg-seashell-50 hover:bg-seashell-100 rounded-xl font-semibold transition-colors flex items-center justify-between">
              <span>Ver propiedades guardadas</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </button>

            <button class="w-full py-4 text-left px-6 bg-seashell-50 hover:bg-seashell-100 rounded-xl font-semibold transition-colors flex items-center justify-between">
              <span>Ver historial de búsquedas</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seashell-600">
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </button>

            <div class="pt-6 border-t border-seashell-100 space-y-4">
              <button class="w-full py-4 px-6 border border-yellow-200 text-yellow-800 hover:bg-yellow-50 rounded-xl font-semibold transition-colors">
                Limpiar historial de búsquedas
              </button>
              <button class="w-full py-4 px-6 border border-red-200 text-red-600 hover:bg-red-50 rounded-xl font-semibold transition-colors">
                Borrar todos los datos locales
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
