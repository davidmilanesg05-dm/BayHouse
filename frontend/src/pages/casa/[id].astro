---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { supabase, type Property } from '../../lib/supabase';

export const prerender = false;

// Obtener ID y propiedad
const { id } = Astro.params;

const { data: casaData, error } = await supabase
  .from('properties')
  .select('*')
  .eq('id', id)
  .single();
---

<Layout>
  <div class="bg-background min-h-screen">
    <!-- Navbar -->
    <nav class="bg-background border-b border-border sticky top-0 z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="font-semibold">Volver</span>
        </a>
          
          <div class="flex gap-2">
            <button class="p-2 rounded-full hover:bg-muted transition-colors">
              
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgShare2" aria-hidden="true"><path d="M21 5.841a2.8 2.8 0 11-2.8-2.8 2.8 2.8 0 012.8 2.8zM18.2 15.4a2.8 2.8 0 102.8 2.8 2.8 2.8 0 00-2.8-2.8zM5.8 9.22a2.8 2.8 0 102.8 2.8 2.8 2.8 0 00-2.8-2.8zm9.6-2.2l-6.8 3.551m7 6.6l-7-3.8"></path></svg>
            </button>
            <button id="favoriteBtn" class="p-2 rounded-full hover:bg-muted transition-colors" data-property-id={casaData ? String(casaData.id) : undefined}>
              <svg id="heartIcon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgHeart" aria-hidden="true"><path d="M19.616 5.673a4.738 4.738 0 00-6.7 0L12 6.586l-.913-.913a4.739 4.739 0 00-6.7 6.7l.913.913 6.7 6.7 6.7-6.7.913-.913a4.738 4.738 0 000-6.7z"></path></svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    {casaData ? (
      <>
        <!-- Slider de Imágenes -->
        <div class="relative">
          <div class="aspect-video bg-muted">
            <img id="mainImage" src={casaData.main_image_url} alt={casaData.title} class="w-full h-full object-cover">
          </div>
          
          <!-- Thumbnails -->
          <div class="flex gap-2 p-4 overflow-x-auto">
            <button 
              class="flex-shrink-0 w-20 h-16 rounded-lg overflow-hidden border-2 transition-all border-primary"
              data-index="0"
              data-src={casaData.main_image_url}
              onclick="changeImage(this)"
            >
              <img src={casaData.main_image_url} alt="Imagen 1" class="w-full h-full object-cover">
            </button>
            {casaData.other_image_urls?.map((img, i) => (
              <button 
                key={i} 
                class="flex-shrink-0 w-20 h-16 rounded-lg overflow-hidden border-2 transition-all border-transparent hover:border-border"
                data-index={i+1}
                data-src={img}
                onclick="changeImage(this)"
              >
                <img src={img} alt={`Imagen ${i+2}`} class="w-full h-full object-cover">
              </button>
            )) || []}
          </div>
        </div>

        <!-- Contenido Principal -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <!-- Precio y Título -->
          <div class="mb-8">
            <div class="text-3xl font-bold text-foreground mb-2">{casaData.price}</div>
            <h1 class="text-2xl font-semibold text-foreground mb-2">{casaData.title}</h1>
            <div class="flex items-center gap-2 text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" data-icon="SvgMapPin" aria-hidden="true"><path d="M17.116 13.391h0L12 21l-5.258-7.8q-.1-.135-.186-.276l-.027-.04h0a6.459 6.459 0 1110.585.505zM12 7.175a2.3 2.3 0 102.3 2.3 2.3 2.3 0 00-2.3-2.3z"></path></svg>
              <span>{casaData.location}</span>
            </div>
          </div>

          <!-- Características -->
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
            <div class="text-center p-4 bg-card border border-border rounded-xl">
              <div class="flex justify-center mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M80-200v-240q0-27 11-49t29-39v-112q0-50 35-85t85-35h160q23 0 43 8.5t37 23.5q17-15 37-23.5t43-8.5h160q50 0 85 35t35 85v112q18 17 29 39t11 49v240h-80v-80H160v80H80Zm440-360h240v-80q0-17-11.5-28.5T720-680H560q-17 0-28.5 11.5T520-640v80Zm-320 0h240v-80q0-17-11.5-28.5T400-680H240q-17 0-28.5 11.5T200-640v80Zm-40 200h640v-80q0-17-11.5-28.5T760-480H200q-17 0-28.5 11.5T160-440v80Zm640 0H160h640Z"/></svg>
              </div>
              <div class="font-semibold text-foreground">{casaData.beds}</div>
              <div class="text-sm text-muted-foreground">Habitaciones</div>
            </div>

            <div class="text-center p-4 bg-card border border-border rounded-xl">
              <div class="flex justify-center mb-2">
               <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M223.5-623.5Q200-647 200-680t23.5-56.5Q247-760 280-760t56.5 23.5Q360-713 360-680t-23.5 56.5Q313-600 280-600t-56.5-23.5ZM200-80q-17 0-28.5-11.5T160-120q-33 0-56.5-23.5T80-200v-240h120v-30q0-38 26-64t64-26q20 0 37 8t31 22l56 62q8 8 15.5 15t16.5 13h274v-326q0-14-10-24t-24-10q-6 0-11.5 2.5T664-790l-50 50q5 17 2 33.5T604-676L494-788q14-9 30-11.5t32 3.5l50-50q16-16 36.5-25t43.5-9q48 0 81 33t33 81v326h80v240q0 33-23.5 56.5T800-120q0 17-11.5 28.5T760-80H200Zm-40-120h640v-160H160v160Zm0 0h640-640Z"/></svg>
              </div>
              <div class="font-semibold text-foreground">{casaData.baths}</div>
              <div class="text-sm text-muted-foreground">Baños</div>
            </div>

            <div class="text-center p-4 bg-card border border-border rounded-xl">
              <div class="flex justify-center mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M208-120q-37 0-62.5-25.5T120-208v-548q0-29 27-40.5t47 8.5l90 90-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 80 80q20 20 8.5 47T756-120H208Zm32-120h332L240-572v332Z"/></svg>
              </div>
              <div class="font-semibold text-foreground">{casaData.sqft}</div>
              <div class="text-sm text-muted-foreground">m²</div>
            </div>

            {casaData.garage && (
              <div class="text-center p-4 bg-card border border-border rounded-xl">
                <div class="flex justify-center mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M160-80q-33 0-56.5-23.5T80-160v-640q0-33 23.5-56.5T160-880h640q33 0 56.5 23.5T880-800v640q0 33-23.5 56.5T800-80H160Zm0-80h640v-640H160v640Zm171.5-251.5Q320-423 320-440t11.5-28.5Q343-480 360-480t28.5 11.5Q400-457 400-440t-11.5 28.5Q377-400 360-400t-28.5-11.5Zm240 0Q560-423 560-440t11.5-28.5Q583-480 600-480t28.5 11.5Q640-457 640-440t-11.5 28.5Q617-400 600-400t-28.5-11.5ZM200-516v264q0 14 9 23t23 9h16q14 0 23-9t9-23v-48h400v48q0 14 9 23t23 9h16q14 0 23-9t9-23v-264l-66-192q-5-14-16.5-23t-25.5-9H308q-14 0-25.5 9T266-708l-66 192Zm106-64 28-80h292l28 80H306ZM160-800v640-640Zm120 420v-120h400v120H280Z"/></svg>
                </div>
                <div class="text-sm text-muted-foreground">Garage</div>
              </div>
            )}

            {casaData.patio && (
              <div class="text-center p-4 bg-card border border-border rounded-xl">
                <div class="flex justify-center mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M200-80v-80h240v-160h-80q-83 0-141.5-58.5T160-520q0-60 33-110.5t89-73.5q9-75 65.5-125.5T480-880q76 0 132.5 50.5T678-704q56 23 89 73.5T800-520q0 83-58.5 141.5T600-320h-80v160h240v80H200Zm160-320h240q50 0 85-35t35-85q0-36-20.5-66T646-630l-42-18-6-46q-6-45-39.5-75.5T480-800q-45 0-78.5 30.5T362-694l-6 46-42 18q-33 14-53.5 44T240-520q0 50 35 85t85 35Zm120-200Z"/></svg>
                </div>
                <div class="text-sm text-muted-foreground">Patio</div>
              </div>
            )}

            {casaData.cistern && (
              <div class="text-center p-4 bg-card border border-border rounded-xl">
                <div class="flex justify-center mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M280-240h400v-347L480-740 280-587v347Zm-80 80v-366L88-440l-47-63 439-337 440 336-48 64-112-86v366H200Zm336.5-183.5Q560-367 560-400q0-27-15-57.5T480-560q-50 72-65 102.5T400-400q0 33 23.5 56.5T480-320q33 0 56.5-23.5ZM480-400Z"/></svg>
                </div>
                <div class="text-sm text-muted-foreground">Cisterna</div>
              </div>
            )}
          </div>

          {casaData.special_circuit && (
            <div class="mb-8 p-4 bg-yellow-950/30 border border-yellow-600 rounded-xl">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff085"><path d="M460-200h40v-74l140-140v-186H320v186l140 140v74Zm-80 80v-120L240-380v-220q0-33 23.5-56.5T320-680h40l-40 40v-200h80v160h160v-160h80v200l-40-40h40q33 0 56.5 23.5T720-600v220L580-240v120H380Zm100-280Z"/></svg>
                <span class="font-semibold text-yellow-200">Circuito Especial</span>
              </div>
            </div>
          )}

          <!-- Descripción -->
          <div class="mb-8">
            <h2 class="text-xl font-semibold mb-4 text-foreground">Descripción</h2>
            <p class="text-foreground/80 leading-relaxed"> • {casaData.description}</p>
          </div>

          <!-- Botón Me Interesa -->
          <div class="mb-12">
            <a href={`https://wa.me/+5354776027?text=Hola,%20estoy%20interesado%20en%20la%20casa%20${encodeURIComponent(casaData.title)}`} target="_blank" class="flex items-center justify-center gap-2 w-56 mx-auto bg-green-500 hover:bg-green-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-colors shadow-lg">
              Me interesa
              
<svg
  xmlns="http://www.w3.org/2000/svg"
  width="32"
  height="32"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
  <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
</svg>

            </a>
          </div>
        </div>
      </>
    ) : (
      <div class="py-20 text-center text-muted-foreground">
        <p class="text-lg font-semibold mb-2">Propiedad no encontrada</p>
        <a href="/propiedades" class="text-foreground font-semibold hover:underline">Volver a propiedades</a>
      </div>
    )}

    <!-- Footer -->
    <Footer />
  </div>

  <script>
    import { gsap } from "gsap";
    
    document.addEventListener('DOMContentLoaded', () => {
      // Image slider
      const slider = document.querySelector('.relative');
      if (slider) {
        gsap.fromTo(slider, { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 0.8, ease: 'power2.out' });
      }
      
      // Content sections
      const content = document.querySelector('.max-w-7xl');
      if (content) {
        gsap.fromTo(content.children, 
          { opacity: 0, y: 40 }, 
          { opacity: 1, y: 0, duration: 0.7, stagger: 0.1, delay: 0.3, ease: 'power2.out' }
        );
      }
    });
  </script>

  <script is:inline>
    function changeImage(element) {
      const mainImage = document.getElementById('mainImage');
      mainImage.src = element.dataset.src;
      
      // Actualizar el borde activo
      const thumbs = document.querySelectorAll('[data-index]');
      thumbs.forEach(thumb => {
        thumb.classList.remove('border-primary');
        thumb.classList.add('border-transparent');
      });
      element.classList.remove('border-transparent');
      element.classList.add('border-primary');
    }

    // Favoritos
    const favoriteBtn = document.getElementById('favoriteBtn');
    const heartIcon = document.getElementById('heartIcon');
    const propertyId = favoriteBtn?.dataset.propertyId;

    function getFavorites() {
      const favs = localStorage.getItem('favorites');
      return favs ? JSON.parse(favs) : [];
    }

    function saveFavorites(favs) {
      localStorage.setItem('favorites', JSON.stringify(favs));
    }

    function updateHeartIcon() {
      const favs = getFavorites();
      const isFavorite = favs.includes(propertyId);
      heartIcon.setAttribute('fill', isFavorite ? 'currentColor' : 'none');
    }

    if (favoriteBtn && propertyId) {
      updateHeartIcon();
      favoriteBtn.addEventListener('click', () => {
        let favs = getFavorites();
        if (favs.includes(propertyId)) {
          favs = favs.filter(id => id !== propertyId);
        } else {
          favs.push(propertyId);
        }
        saveFavorites(favs);
        updateHeartIcon();
      });
    }
  </script>
</Layout>
