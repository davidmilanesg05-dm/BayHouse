---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="bg-background text-foreground min-h-screen">
    <!-- Back Button -->
    <section class="pt-8 px-4">
      <div class="max-w-7xl mx-auto">
        <a href="/" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="font-semibold">Volver</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Términos y <span class="text-primary">Condiciones</span></h1>
        <p class="text-xl md:text-2xl text-muted-foreground max-w-3xl mx-auto">Lee atentamente estos términos antes de usar nuestros servicios.</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">1. Uso del sitio web</h2>
          <p class="text-muted-foreground">
            Al acceder y usar este sitio web, aceptas cumplir con estos términos y condiciones y todas las leyes y regulaciones aplicables.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">2. Propiedad intelectual</h2>
          <p class="text-muted-foreground">
            Todo el contenido de este sitio web (textos, imágenes, logotipos) es propiedad de BayHouse y está protegido por las leyes de propiedad intelectual.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">3. Información de propiedades</h2>
          <p class="text-muted-foreground">
            Nos esforzamos por mantener la información de las propiedades actualizada, pero no garantizamos la exactitud, integridad o actualidad de la información.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">4. Limitación de responsabilidad</h2>
          <p class="text-muted-foreground">
            BayHouse no será responsable por ningún daño directo o indirecto que surja del uso de este sitio web o de la información contenida en él.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">5. Modificaciones</h2>
          <p class="text-muted-foreground">
            Nos reservamos el derecho de modificar estos términos y condiciones en cualquier momento. Las modificaciones serán efectivas inmediatamente después de su publicación en el sitio web.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">6. Ley aplicable</h2>
          <p class="text-muted-foreground">
            Estos términos y condiciones se rigen por las leyes de Cuba. Cualquier disputa se resolverá en los tribunales de Bayamo.
          </p>
        </div>

        <div class="bg-card p-8 mb-4 rounded-2xl shadow-lg border border-border">
          <h2 class="text-2xl font-bold mb-4">7. Contacto</h2>
          <p class="text-muted-foreground">
            Si tienes preguntas sobre estos términos y condiciones, puedes contactarnos a través de nuestra página de contacto.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener('DOMContentLoaded', () => {
    // Hero section
    const heroTitle = document.querySelector('h1');
    const heroSubtitle = document.querySelector('h1 + p');
    
    if (heroTitle) {
      gsap.fromTo(heroTitle, { opacity: 0, y: 50 }, { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
    }
    if (heroSubtitle) {
      gsap.fromTo(heroSubtitle, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: 'power2.out' });
    }
    
    // Terms cards
    const termsCards = document.querySelectorAll('.bg-card');
    if (termsCards.length > 0) {
      gsap.fromTo(termsCards, 
        { opacity: 0, y: 40 }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.6, 
          stagger: 0.1, 
          ease: 'power2.out',
          scrollTrigger: {
            trigger: termsCards[0].parentElement,
            start: 'top 80%'
          }
        }
      );
    }
  });
</script>