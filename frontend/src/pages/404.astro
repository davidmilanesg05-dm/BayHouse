---
import Layout from '../layouts/Layout.astro';
---

<Layout hideFooter={true}>
  <main id="error-page" class="bg-background text-foreground min-h-screen flex items-center justify-center py-20 px-4">
    <div id="error-content" class="max-w-2xl mx-auto text-center">
      <div id="error-number" class="text-9xl font-black text-primary mb-8 opacity-0 translate-y-10">404</div>
      <h1 id="error-title" class="text-4xl md:text-5xl font-bold text-foreground mb-6 opacity-0 translate-y-10">Página no encontrada</h1>
      <p id="error-message" class="text-xl text-muted-foreground mb-10 max-w-lg mx-auto opacity-0 translate-y-10">
        Lo sentimos, la página que buscas no existe o ha sido movida.
      </p>
      <div id="error-buttons" class="flex flex-col sm:flex-row gap-4 justify-center opacity-0 translate-y-10">
        <a href="/" class="bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </main>
  <script type="module">
    import { gsap } from 'gsap';

    const timeline = gsap.timeline();
    
    timeline
      .to('#error-number', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.7)' })
      .to('#error-title', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.4')
      .to('#error-message', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')
      .to('#error-buttons', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3');
  </script>
</Layout>